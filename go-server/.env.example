# Milestone 3 process and client-session configuration
BLOCKFORGE_ENV=development
BLOCKFORGE_HTTP_ADDRESS=:8080
BLOCKFORGE_HTTP_READ_HEADER_TIMEOUT=5s
BLOCKFORGE_HTTP_READ_TIMEOUT=15s
BLOCKFORGE_HTTP_WRITE_TIMEOUT=15s
BLOCKFORGE_HTTP_IDLE_TIMEOUT=60s
BLOCKFORGE_SHUTDOWN_TIMEOUT=10s
BLOCKFORGE_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
BLOCKFORGE_MAX_CONNECTIONS=1000
BLOCKFORGE_OUTBOUND_QUEUE_CAPACITY=64
BLOCKFORGE_WS_READ_TIMEOUT=60s
BLOCKFORGE_WS_WRITE_TIMEOUT=10s

# Milestone 15 Broker configuration (uncomment for multi-node NATS JetStream setup)
# BLOCKFORGE_BROKER_URL=nats://localhost:4222
# BLOCKFORGE_NODE_ID=node_1